{
  "name": "revamp",
  "displayName": "ReVamp",
  "description": "Scaffold an AI-powered ReVamp project from the command palette",
  "version": "0.1.0",
  "publisher": "j2kenton",
  "license": "MIT",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Other"],
  "keywords": ["scaffold", "template", "nextjs", "ai", "starter"],
  "repository": {
    "type": "git",
    "url": "https://github.com/j2kenton/revamp-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/j2kenton/revamp-vscode/issues"
  },
  "homepage": "https://github.com/j2kenton/revamp-vscode#readme",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "revamp.newProject",
        "title": "ReVamp: New Project"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
