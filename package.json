{
  "name": "revamp",
  "displayName": "ReVamp",
  "description": "Scaffold a new ReVamp project from the command palette",
  "version": "0.1.0",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "revamp.newProject",
        "title": "ReVamp: New Project"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
