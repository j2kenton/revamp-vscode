{
  "name": "revamp",
  "displayName": "ReVamp",
  "description": "Create a ReVamp starter project from the command palette",
  "version": "0.1.0",
  "publisher": "j2kenton",
  "license": "MIT",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Other"],
  "keywords": ["scaffold", "template", "nextjs", "starter"],
  "files": [
    "out/**",
    "template/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/j2kenton/revamp-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/j2kenton/revamp-vscode/issues"
  },
  "homepage": "https://github.com/j2kenton/revamp-vscode#readme",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "revamp.newProject",
        "title": "ReVamp: New Project"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run sync-template && npm run compile",
    "sync-template": "node scripts/sync-template.js",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies && node scripts/sanitize-vsix.js revamp-0.1.0.vsix",
    "publish": "npm run package && vsce publish --packagePath revamp-0.1.0.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
